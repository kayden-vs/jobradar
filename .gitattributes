# Enforce LF line endings for all text files
# This prevents Windows/WSL git disagreements caused by CRLF vs LF
* text=auto eol=lf

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# Config / data files
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf
*.ini  text eol=lf
*.env  text eol=lf

# Docs
*.md  text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Web / misc
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Binary files — no line-ending conversion
*.pdf  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pem  binary
*.db   binary
*.sqlite binary
